# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# LLM API Keys (at least one required)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Default LLM Provider: openai | anthropic | gemini
DEFAULT_LLM_PROVIDER=openai

# FHIR Server (optional - for validation)
FHIR_VALIDATION_SERVER=https://hapi.fhir.org/baseR4

# NHCX Configuration
NHCX_BASE_URL=https://claims.sandbox.abdm.gov.in
NHCX_PARTICIPANT_CODE=your_participant_code

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
